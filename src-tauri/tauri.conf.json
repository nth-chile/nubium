{
  "$schema": "https://raw.githubusercontent.com/nicholasxjy/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Nubium",
  "version": "0.1.0",
  "identifier": "com.nubium.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nubium",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
