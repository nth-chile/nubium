{
  "identifier": "default",
  "description": "Default capability for Nubium",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-mkdir",
    "fs:allow-appconfig-read",
    "fs:allow-appconfig-write",
    "fs:allow-appconfig-meta"
  ]
}
